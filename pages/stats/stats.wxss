.container {
  padding: 20rpx;
  background: #f5f7fa;
  min-height: 100vh;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.stats-item {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 0;
  font-size: 28rpx;
}
.stats-text {
  font-size: 28rpx;
  color: #333;
}