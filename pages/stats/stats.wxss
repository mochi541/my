.container{
  padding: 20rpx;
  background: #f5f7fa;
  min-height: 100vh;
}
.card{
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
  margin-bottom: 20rpx;
}
.title{
  font-size: 28rpx;
  color: #666;
}
.total{
  font-size: 50rpx;
  font-weight: bold;
  color: #409EFF;
  margin-top: 10rpx;
}
.chart-card{
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.subtitle{
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.chart{
  width: 100%;
  height: 400rpx;
}
.list{
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
}
.item{
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}