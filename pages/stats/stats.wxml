<view class="container">
  <view class="card">
    <view class="title">近7天用眼统计</view>
    <view class="stats-item" wx:for="{{list}}" wx:key="index">
      <text>{{item.date}}</text>
      <text>{{item.studyMinutes}} 分钟</text>
    </view>
  </view>

  <view class="card">
    <view class="stats-text">日均学习：{{avgTime}} 分钟</view>
  </view>
</view>