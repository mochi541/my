.container {
  padding: 20rpx;
  background: #f5f7fa;
  min-height: 100vh;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}
.title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.set-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  font-size: 28rpx;
}
.picker-text {
  color: #409EFF;
  font-size: 28rpx;
}
.password-input {
  border:1rpx solid #eee;
  border-radius:10rpx;
  padding:20rpx;
  margin-bottom:20rpx;
}