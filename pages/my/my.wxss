.container{
  padding: 20rpx;
  background: #f5f7fa;
  min-height: 100vh;
}
.userInfo{
  background: #409EFF;
  color: white;
  padding: 40rpx;
  border-radius: 20rpx;
  text-align: center;
  margin-bottom: 30rpx;
}
.avatar{
  font-size: 70rpx;
  margin-bottom: 10rpx;
}
.name{
  font-size: 32rpx;
}
.menu{
  background: white;
  border-radius: 20rpx;
}
.item{
  padding: 30rpx;
  font-size: 28rpx;
  border-bottom: 1rpx solid #eee;
}
.red{
  color: #ff4444;
}