<view class="container">
  <!-- 学习时长卡片 -->
  <view class="card">
    <view class="label">今日学习时长</view>
    <view class="time">{{formatTime(studyTime)}}</view>
    <view class="desc">已专注 {{studyTimeText}}</view>
  </view>

  <!-- 控制按钮 -->
  <view class="btn-group">
    <button class="btn start" wx:if="{{!isRunning}}" bindtap="startTimer">
      开始学习
    </button>
    <button class="btn stop" wx:else bindtap="stopTimer">
      结束学习
    </button>
  </view>

  <!-- 护眼提示 -->
  <view class="tip-card" bindtap="showEyeRule">
    <view class="tip-icon">👁</view>
    <view class="tip-text">20-20-20 护眼法则：每学习20分钟，远眺20秒</view>
  </view>
</view>