<view class="container">
  <view class="card">
    <view class="title">每日护眼任务</view>
    <view class="task" wx:for="{{taskList}}" wx:key="id">
      <view>{{item.title}}</view>
      <switch checked="{{item.done}}" disabled />
    </view>
  </view>

  <view class="card">
    <view class="title">护眼小知识</view>
    <view class="tip">每20分钟远眺20秒</view>
    <view class="tip">每天户外2小时</view>
    <view class="tip">保持33cm阅读距离</view>
  </view>
</view>